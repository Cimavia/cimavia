# Server
PORT=3000
NODE_ENV=development

# Database
# Local : Postgres via apps/api/docker-compose.yml (hôte sur 5432).
DATABASE_URL="postgresql://cimavia:cimavia@localhost:5432/cimavia?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Sentry
SENTRY_DSN=

# Axiom
AXIOM_DATASET=
AXIOM_TOKEN=

# Auth (Better Auth)
# Secret de signature — générer via : openssl rand -base64 32
BETTER_AUTH_SECRET=
# URL publique de l'API (base des liens d'auth, ex. reset password)
BETTER_AUTH_URL=http://localhost:3000
# Metro Expo dev server
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:8081
# Origines navigateur autorisées (CORS + trustedOrigins), séparées par des virgules
CORS_ORIGINS=http://localhost:5173

# Object storage S3-compatible. Bucket PRIVÉ — accès uniquement via URLs signées.
# Laisser vide désactive l'upload (l'API démarre ; les endpoints documents renvoient 503).
# --- Dev local : MinIO (docker-compose.yml) — aucun compte cloud requis ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=cimavia-media-dev
S3_ACCESS_KEY_ID=cimavia
S3_SECRET_ACCESS_KEY=cimavia_dev_secret
S3_FORCE_PATH_STYLE=true
# --- Prod (Scaleway) : remplacer par ---
# S3_ENDPOINT=https://s3.fr-par.scw.cloud
# S3_REGION=fr-par
# S3_BUCKET=<nom-bucket-scaleway>
# S3_ACCESS_KEY_ID=<access-key>
# S3_SECRET_ACCESS_KEY=<secret-key>
# S3_FORCE_PATH_STYLE=false
# --- Notifications push (Expo) ---
# Aucun secret n'est requis pour envoyer : les push partent sans ce token. Il ne devient
# nécessaire que si « Enhanced Security » est activé sur le compte Expo (expo.dev).
EXPO_ACCESS_TOKEN=
