generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth — tables gérées par Better Auth (voir apps/api/src/auth/…).
// Le `User` porte le profil via *additionalFields* Better Auth : `role` et `locale`
// sont des scalaires (String) validés côté app par @cmv/shared (Role, Locale) —
// pas des enums Postgres, car Better Auth ne gère que des types scalaires.
// Optionnel : `npx @better-auth/cli generate` peut resynchroniser ces modèles.
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  // additionalFields Better Auth (validés par @cmv/shared) :
  role          String // Role : COACH | ATHLETE | ADMIN
  locale        String   @default("fr") // Locale : fr | en
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Auth
  sessions AuthSession[]
  accounts Account[]

  // Métier — tenancy (relation coach↔athlète nullable/réversible)
  athleteRelation     CoachAthlete?  @relation("AthleteRelation") // athlète → au plus 1 coach
  coachRelations      CoachAthlete[] @relation("CoachRelations") // coach → N athlètes
  coachInvitations    Invitation[]   @relation("CoachInvitations")
  acceptedInvitations Invitation[]   @relation("AthleteAcceptedInvitations")
  athleteSheet        AthleteSheet?  @relation("AthleteSheetAthlete") // fiche de l'athlète
  coachSheets         AthleteSheet[] @relation("AthleteSheetCoach") // fiches rédigées par le coach

  // Métier — bibliothèque du coach (P2)
  exercises     Exercise[] @relation("CoachExercises") // exercices du coach
  coachSessions Session[]  @relation("CoachSessions") // séances (modèles) du coach

  // Métier — planifications (P3) : premier objet lu par les DEUX rôles.
  coachPlans   Plan[] @relation("CoachPlans") // planifs écrites par le coach
  athletePlans Plan[] @relation("AthletePlans") // planifs reçues par l'athlète

  // Métier — débriefs (P4) : écrits par l'athlète, lus par le coach.
  athleteFeedback SessionFeedback[] @relation("AthleteFeedback")
  coachFeedback   SessionFeedback[] @relation("CoachFeedback")

  // Métier — messagerie (P5) : fil 1:1 lu et écrit par les DEUX rôles.
  coachConversations   Conversation[] @relation("CoachConversations")
  athleteConversations Conversation[] @relation("AthleteConversations")
  sentMessages         Message[]      @relation("SentMessages")

  // Notifications push — les DEUX rôles enregistrent leurs appareils (P4).
  pushTokens PushToken[]

  @@map("user")
}

// Renommé `AuthSession` (table `session` conservée via @@map) pour libérer `Session` au
// profit de l'entité métier séance (P2). Résolu par Better Auth via `session.modelName`.
model AuthSession {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─────────────────────────────────────────────────────────────────────────────
// Métier — fondation multi-tenant (P1).
// Invariant : 1 athlète a AU PLUS 1 coach (0 ou 1, unicité en base) ; 1 coach = N athlètes.
// La relation est une table à part : absence de ligne = athlète autonome (v1.0) ;
// suppression = redevient autonome. Réversible par construction, sans refonte.
// ─────────────────────────────────────────────────────────────────────────────

enum CoachAthleteStatus {
  PENDING
  ACTIVE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model CoachAthlete {
  id        String             @id @default(cuid())
  coachId   String
  coach     User               @relation("CoachRelations", fields: [coachId], references: [id], onDelete: Cascade)
  athleteId String             @unique // unicité → au plus 1 coach par athlète
  athlete   User               @relation("AthleteRelation", fields: [athleteId], references: [id], onDelete: Cascade)
  status    CoachAthleteStatus @default(ACTIVE)
  invitedAt DateTime           @default(now())
  joinedAt  DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([coachId])
  @@map("coach_athlete")
}

model Invitation {
  id                  String           @id @default(cuid())
  code                String           @unique
  email               String? // nominative si présent ; sinon lien générique
  status              InvitationStatus @default(PENDING)
  coachId             String
  coach               User             @relation("CoachInvitations", fields: [coachId], references: [id], onDelete: Cascade)
  acceptedByAthleteId String?
  acceptedByAthlete   User?            @relation("AthleteAcceptedInvitations", fields: [acceptedByAthleteId], references: [id], onDelete: SetNull)
  expiresAt           DateTime
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([coachId])
  @@map("coach_invitation")
}

model AthleteSheet {
  id        String   @id @default(cuid())
  athleteId String   @unique // une fiche par athlète
  athlete   User     @relation("AthleteSheetAthlete", fields: [athleteId], references: [id], onDelete: Cascade)
  coachId   String
  coach     User     @relation("AthleteSheetCoach", fields: [coachId], references: [id], onDelete: Cascade)
  content   String   @default("") // champ libre, éditable par le coach seul (tenancy layer)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([coachId])
  @@map("athlete_sheet")
}

// ─────────────────────────────────────────────────────────────────────────────
// Métier — bibliothèque du coach (P2).
// Exercices et séances (modèles) réutilisables, scopés au coach (coachId).
// Le `coachId` est dénormalisé sur les tables enfant (ExerciseDocument,
// SessionExercise) : le tenancy extension scope chaque modèle par un champ DIRECT,
// donc toute entité métier porte son propre champ tenant (règle dure multi-tenant).
// ─────────────────────────────────────────────────────────────────────────────

enum ExerciseCategory {
  RENFO
  GRIMPE
  TECHNIQUE
}

enum DocumentType {
  FILE // fichier uploadé en object storage (storagePath)
  LINK // lien externe (url) — ex. vidéo YouTube
}

model Exercise {
  id          String           @id @default(cuid())
  coachId     String
  coach       User             @relation("CoachExercises", fields: [coachId], references: [id], onDelete: Cascade)
  title       String
  description String? // consignes — nullable, pas de fallback (règle dure n°5)
  category    ExerciseCategory
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  documents        ExerciseDocument[]
  sessionExercises SessionExercise[]
  // Copies posées dans des planifications (P3) : SetNull → la suppression d'un exercice de la
  // bibliothèque ne casse JAMAIS une planif (l'instance garde son snapshot titre/description).
  scheduledCopies  ScheduledSessionExercise[]

  @@index([coachId])
  @@map("exercise")
}

model ExerciseDocument {
  id          String       @id @default(cuid())
  coachId     String // dénormalisé pour le scope tenant direct
  exerciseId  String
  exercise    Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  type        DocumentType
  storagePath String? // clé objet S3 (type FILE) — jamais le binaire en BDD
  url         String? // lien externe (type LINK)
  fileName    String? // nom d'affichage (type FILE)
  mimeType    String? // type MIME (type FILE)
  createdAt   DateTime     @default(now())

  @@index([coachId])
  @@index([exerciseId])
  @@map("exercise_document")
}

model Session {
  id        String   @id @default(cuid())
  coachId   String
  coach     User     @relation("CoachSessions", fields: [coachId], references: [id], onDelete: Cascade)
  title     String
  notes     String? // consignes globales — nullable, pas de fallback
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exercises SessionExercise[]
  // Instances posées dans des planifications (P3) : SetNull, même raison que Exercise.
  instances ScheduledSession[]

  @@index([coachId])
  // Exception au singulier (convention repo) : `session` est déjà pris par la table auth.
  @@map("sessions")
}

model SessionExercise {
  id           String   @id @default(cuid())
  coachId      String // dénormalisé pour le scope tenant direct
  sessionId    String
  session      Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId   String
  exercise     Exercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  position     Int // ordre dans la séance (0-based)
  prescription String? // prescription pour cet exercice — nullable
  createdAt    DateTime @default(now())

  @@unique([sessionId, position])
  @@index([coachId])
  @@index([exerciseId])
  @@map("session_exercise")
}

// ─────────────────────────────────────────────────────────────────────────────
// Métier — planifications (P3).
// Le Plan est le PREMIER objet lu par les deux rôles : chaque table porte donc `coachId` ET
// `athleteId` en direct (le tenancy extension scope par un champ du modèle lui-même). Le
// scope athlète ne suffit pas à lui seul : un plan DRAFT lui reste invisible grâce au filtre
// `status: PUBLISHED` appliqué par le service athlète — voir PlanService.
//
// Une séance planifiée est une COPIE FIGÉE d'un modèle de séance, pas une référence :
// titre/consignes/exercices (titre, description, catégorie, prescription) et les documents
// sont dupliqués à l'instanciation. Les liens `source*` sont donc nullables (`SetNull`) et ne
// servent qu'à la traçabilité — la bibliothèque du coach reste librement modifiable et
// supprimable sans jamais dégrader une planif déjà diffusée.
//
// Les documents copiés PARTAGENT la clé objet S3 de l'original (aucune duplication de binaire) :
// la suppression d'un document/exercice de la bibliothèque ne purge donc l'objet que s'il n'est
// plus référencé par une copie (garde de comptage côté service).
// ─────────────────────────────────────────────────────────────────────────────

enum PlanStatus {
  DRAFT // en construction — invisible de l'athlète
  PUBLISHED // diffusée — visible de l'athlète, notification envoyée
}

enum PlanWeekType {
  TRAINING
  DELOAD // décharge
}

enum ScheduledSessionStatus {
  PLANNED // posée par le coach (état initial et seul état écrit en P3)
  DONE // transition portée par le débrief (P4)
  SKIPPED
}

model Plan {
  id          String     @id @default(cuid())
  coachId     String
  coach       User       @relation("CoachPlans", fields: [coachId], references: [id], onDelete: Cascade)
  athleteId   String
  athlete     User       @relation("AthletePlans", fields: [athleteId], references: [id], onDelete: Cascade)
  title       String
  description String? // description du cycle — nullable, pas de fallback
  // Date civile (pas d'horaire, pas de fuseau) : toujours un LUNDI (planStartDateSchema).
  // Les dates des semaines s'en déduisent (planWeekRange) — rien n'est stocké sur PlanWeek.
  startDate   DateTime   @db.Date
  status      PlanStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  weeks             PlanWeek[]
  scheduledSessions ScheduledSession[]

  @@index([coachId])
  @@index([athleteId, status]) // lecture athlète : ses plans diffusés
  @@map("plan")
}

model PlanWeek {
  id         String       @id @default(cuid())
  // coachId/athleteId recopiés du Plan parent : l'extension tenant filtre par un champ du
  // modèle INTERROGÉ (`where: { coachId }`), elle ne sait pas remonter la relation
  // (`where: { plan: { coachId } }`). Sans ces colonnes, la semaine serait non scopable.
  // L'extension les injecte elle-même à la création — aucun service ne les renseigne.
  coachId    String
  athleteId  String
  planId     String
  plan       Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  weekNumber Int // 1-based ; nombre de semaines LIBRE (CDC §5.4)
  type       PlanWeekType
  note       String? // note de semaine — nullable
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  sessions ScheduledSession[]

  @@unique([planId, weekNumber])
  @@index([coachId])
  @@index([athleteId])
  @@map("plan_week")
}

model ScheduledSession {
  id              String                 @id @default(cuid())
  coachId         String
  athleteId       String
  planId          String
  plan            Plan                   @relation(fields: [planId], references: [id], onDelete: Cascade)
  planWeekId      String
  planWeek        PlanWeek               @relation(fields: [planWeekId], references: [id], onDelete: Cascade)
  sourceSessionId String? // modèle d'origine — traçabilité seule
  sourceSession   Session?               @relation(fields: [sourceSessionId], references: [id], onDelete: SetNull)
  title           String // copié du modèle, puis éditable
  notes           String? // consignes globales — nullable
  scheduledDate   DateTime               @db.Date // dans la plage de sa semaine (invariant service)
  position        Int // ordre dans la journée (0-based)
  status          ScheduledSessionStatus @default(PLANNED)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  exercises ScheduledSessionExercise[]
  feedback  SessionFeedback? // au plus un débrief par séance (P4)
  messages  Message[] // messages rattachés à cette séance (P5) — SetNull à la suppression

  @@unique([planWeekId, scheduledDate, position]) // plusieurs séances par jour, ordonnées
  @@index([coachId])
  @@index([athleteId, scheduledDate]) // vue semaine / liste des séances de l'athlète
  @@index([planId])
  @@index([sourceSessionId])
  @@map("scheduled_session")
}

model ScheduledSessionExercise {
  id                 String           @id @default(cuid())
  coachId            String
  athleteId          String
  scheduledSessionId String
  scheduledSession   ScheduledSession @relation(fields: [scheduledSessionId], references: [id], onDelete: Cascade)
  sourceExerciseId   String? // exercice d'origine — traçabilité seule
  sourceExercise     Exercise?        @relation(fields: [sourceExerciseId], references: [id], onDelete: SetNull)
  title              String // snapshot : l'affichage ne dépend jamais de sourceExercise
  description        String?
  category           ExerciseCategory
  prescription       String? // prescription pour cet athlète — nullable
  position           Int // ordre dans la séance (0-based)
  createdAt          DateTime         @default(now())

  documents ScheduledSessionExerciseDocument[]

  @@unique([scheduledSessionId, position])
  @@index([coachId])
  @@index([athleteId])
  @@index([sourceExerciseId])
  @@map("scheduled_session_exercise")
}

model ScheduledSessionExerciseDocument {
  id                         String                   @id @default(cuid())
  coachId                    String
  athleteId                  String // sans cette copie, l'athlète ne pourrait PAS lire les documents
  scheduledSessionExerciseId String
  scheduledSessionExercise   ScheduledSessionExercise @relation(fields: [scheduledSessionExerciseId], references: [id], onDelete: Cascade)
  type                       DocumentType
  storagePath                String? // MÊME clé objet que le document d'origine (type FILE)
  url                        String? // lien externe (type LINK)
  fileName                   String?
  mimeType                   String?
  createdAt                  DateTime                 @default(now())

  @@index([coachId])
  @@index([athleteId])
  @@index([scheduledSessionExerciseId])
  @@index([storagePath]) // garde de comptage avant purge d'un objet S3 encore référencé
  @@map("scheduled_session_exercise_document")
}

// ─────────────────────────────────────────────────────────────────────────────
// Métier — débrief & médias (P4).
// Le débrief est écrit par l'ATHLÈTE et lu par le COACH : les deux tables portent donc
// `coachId` ET `athleteId` en direct, comme la planification (le tenancy extension scope par
// un champ du modèle interrogé, il ne remonte pas les relations).
//
// ⚠️ Le scope tenant ne dit rien du STATUT : seul le service impose qu'une séance débriefée
// appartienne à un plan PUBLISHED (un brouillon n'est pas débriefable) — voir FeedbackService.
//
// Contrairement aux documents de la bibliothèque, un média de débrief n'est JAMAIS copié ni
// partagé : sa clé objet n'appartient qu'à lui. Sa suppression purge donc l'objet directement,
// sans garde de comptage (pas de nouveau cas d'orphelin — cf. dettes P2-1/P3-2).
// ─────────────────────────────────────────────────────────────────────────────

enum MediaType {
  IMAGE
  VIDEO
  AUDIO // débrief vocal (P5) — note vocale de l'athlète, m4a
}

model SessionFeedback {
  id                 String           @id @default(cuid())
  coachId            String // dénormalisé : le coach LIT le débrief de son athlète
  coach              User             @relation("CoachFeedback", fields: [coachId], references: [id], onDelete: Cascade)
  athleteId          String
  athlete            User             @relation("AthleteFeedback", fields: [athleteId], references: [id], onDelete: Cascade)
  scheduledSessionId String           @unique // un seul débrief par séance (CDC §5.6)
  scheduledSession   ScheduledSession @relation(fields: [scheduledSessionId], references: [id], onDelete: Cascade)
  content            String? // texte libre — nullable : un débrief peut n'être que des médias
  // Marqueur de lecture du coach : alimente la tuile « Débriefs à relire ». Repassé à null
  // quand l'athlète complète son débrief, sinon un ajout tardif ne serait jamais resignalé.
  coachReadAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  media    FeedbackMedia[]
  messages Message[] // messages rattachés à ce débrief (P5) — SetNull à la suppression

  @@index([coachId, coachReadAt]) // tuile dashboard : les débriefs non lus du coach
  @@index([athleteId])
  @@map("session_feedback")
}

model FeedbackMedia {
  id                String          @id @default(cuid())
  coachId           String
  athleteId         String
  sessionFeedbackId String
  sessionFeedback   SessionFeedback @relation(fields: [sessionFeedbackId], references: [id], onDelete: Cascade)
  type              MediaType
  storagePath       String // clé objet S3 — jamais le binaire en BDD
  fileName          String
  mimeType          String
  sizeBytes         Int
  durationSeconds   Int? // vidéo uniquement — déclaré par le client (pas de décodage serveur)
  createdAt         DateTime        @default(now())

  @@index([coachId])
  @@index([athleteId])
  @@index([sessionFeedbackId])
  @@map("feedback_media")
}

// ─────────────────────────────────────────────────────────────────────────────
// Notifications push (P4).
// Un token adresse une INSTALLATION de l'app, pas un utilisateur : d'où une table (plusieurs
// appareils par personne) plutôt qu'une colonne sur User. Le token change (réinstallation,
// restauration) → `@unique` pour que le réenregistrement mette à jour la ligne existante.
// Scopé `userId` pour les deux rôles : chacun ne gère que ses propres appareils. L'ENVOI, lui,
// lit les tokens du DESTINATAIRE (un autre tenant) — il passe donc par le client Prisma de
// base, cf. NotificationService.
// ─────────────────────────────────────────────────────────────────────────────

enum PushPlatform {
  IOS
  ANDROID
}

model PushToken {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String       @unique // ExponentPushToken[…] — l'adresse de livraison
  platform  PushPlatform // sans effet sur la livraison (Expo route seul) : diagnostic prod
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId])
  @@map("push_token")
}

// ─────────────────────────────────────────────────────────────────────────────
// Messagerie (P5) — communication asynchrone coach ↔ athlète (CDC §5.8).
// Fil 1:1 : les DEUX rôles lisent ET écrivent, d'où `coachId` ET `athleteId` en direct sur les
// deux tables (le tenancy extension scope par un champ du modèle interrogé, pas par la relation).
// Un `@@unique([coachId, athleteId])` garantit un seul fil par relation et rend la course du
// get-or-create inoffensive (le 2e create échoue en P2002, on relit).
//
// MVP : asynchrone (polling TanStack Query + push). WebSocket temps réel différé post-MVP.
// ─────────────────────────────────────────────────────────────────────────────

// Un message est SOIT du texte SOIT un média (audio/image/vidéo) — jamais les deux (pas de
// légende sur média en MVP). TEXT n'est donc pas un `MediaType` : enum dédié, découplé du débrief
// (le débrief vocal ajoutera `AUDIO` à `MediaType`, pas ici).
enum MessageType {
  TEXT
  AUDIO
  IMAGE
  VIDEO
}

model Conversation {
  id            String    @id @default(cuid())
  coachId       String
  coach         User      @relation("CoachConversations", fields: [coachId], references: [id], onDelete: Cascade)
  athleteId     String
  athlete       User      @relation("AthleteConversations", fields: [athleteId], references: [id], onDelete: Cascade)
  // Dernier message posté : tri de la liste de conversations du coach, sans agréger les messages.
  // Nullable tant qu'aucun message n'a été envoyé (pas de fallback silencieux).
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages Message[]

  @@unique([coachId, athleteId]) // 1:1 par relation ; garde la course du get-or-create
  @@index([coachId])
  @@index([athleteId])
  @@map("conversation")
}

model Message {
  id             String       @id @default(cuid())
  coachId        String // dénormalisé (scope tenant — un include imbriqué n'est pas scopé)
  athleteId      String // dénormalisé
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  // Auteur du message : coachId ou athleteId. Détermine l'alignement des bulles et le destinataire
  // du push (l'AUTRE partie). Pas de FK relation métier : lu tel quel côté client.
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  type           MessageType
  content        String? // texte (type TEXT) — nullable
  // Média (type AUDIO | IMAGE | VIDEO) : clé objet S3 + métadonnées, jamais le binaire en BDD.
  storagePath     String?
  fileName        String?
  mimeType        String?
  sizeBytes       Int?
  durationSeconds Int? // audio/vidéo — déclaré par le client (pas de décodage serveur)
  // Rattachement optionnel à une séance ou un débrief (« à propos de… »). Nullable/SetNull :
  // supprimer la cible n'efface pas le message, il perd juste son contexte.
  scheduledSessionId String?
  scheduledSession   ScheduledSession? @relation(fields: [scheduledSessionId], references: [id], onDelete: SetNull)
  sessionFeedbackId  String?
  sessionFeedback    SessionFeedback?  @relation(fields: [sessionFeedbackId], references: [id], onDelete: SetNull)
  // Lu par le DESTINATAIRE (pas l'auteur) : alimente `unreadCount` et le throttle push
  // « first-unread » (on ne notifie qu'au passage de « tout lu » à « non lu »).
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([conversationId, createdAt]) // fil chronologique
  @@index([coachId])
  @@index([athleteId])
  @@index([scheduledSessionId])
  @@index([sessionFeedbackId])
  @@map("message")
}
