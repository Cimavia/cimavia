{
  "expo": {
    "name": "cimavia",
    "slug": "cimavia",
    "version": "1.0.0",
    "scheme": "cimavia",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fr.cimavia.app"
    },
    "android": {
      "package": "fr.cimavia.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-font", "expo-secure-store", "expo-localization"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "412cffac-62a8-432c-9f18-04107c70e2cb"
      }
    }
  }
}
