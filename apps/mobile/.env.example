# URL de l'API NestJS (Better Auth y ajoute /api/auth).
# Sur appareil/émulateur physique, remplacer localhost par l'IP LAN de la machine hôte.
EXPO_PUBLIC_API_URL=http://localhost:3000

# Hôte que Metro annonce au device (lu par Expo au démarrage). À définir sous WSL2 (mode NAT) :
# sans ça Metro annonce son IP interne 172.x, injoignable depuis le téléphone. Mettre l'IP LAN
# Windows (ipconfig), la même que ci-dessus. Sur macOS/Linux natif : inutile.
# ⚠️ À placer dans un fichier .env.LOCAL (pas .env) : Expo SDK 56 refuse les variables
# non-EXPO_PUBLIC_ dans un .env ordinaire.
# REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.x   → dans apps/mobile/.env.local
